# Keep npm cache inside the workspace so Electron packaging does not write to
# protected locations such as C:\Program Files\nodejs\node_cache.
cache=.npm-cache

# Quasar app-vite appends pnpm compatibility settings to Electron UnPackaged
# .npmrc when these tokens are absent. Keep them as comments so npm ignores
# them while Quasar does not generate npm-unknown project configs.
# shamefully-hoist intentionally omitted for npm
# node-linker intentionally omitted for npm
